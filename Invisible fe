-- 初始化
createGUI()
toggleButton.MouseButton1Click:Connect(toggleInvisibility)

UserInputService.InputBegan:Connect(function(input, processed)
	if not processed and input.KeyCode == CONFIG.TOGGLE_KEY then
		toggleInvisibility()
	end
end)

