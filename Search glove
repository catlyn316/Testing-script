-- buildSearchResults 需要前向引用 detailView，故定義在詳細界面建立之後
function buildSearchResults(query, diffFilter_)
    for _, b in ipairs(currentSearchBtns) do
        if b then pcall(function() b:Destroy() end) end
    end
    currentSearchBtns = {}

    query = (query or ""):lower()
    local count = 0

    for _, glove in ipairs(GLOVE_DATA) do
        local matchQuery = query == ""
            or glove.en:lower():find(query, 1, true)
            or glove.zh:lower():find(query, 1, true)
        local matchDiff = diffFilter_ == "全部難度" or glove.diff == diffFilter_

        if matchQuery and matchDiff then
            count = count + 1
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -4, 0, currentP2FontSize + 8)
            btn.BackgroundColor3 = THEME.bgRow
            btn.AutoButtonColor = false
            btn.Parent = searchScroll

            local enLbl = Instance.new("TextLabel")
            enLbl.Size = UDim2.new(0.5, -2, 1, 0)
            enLbl.Position = UDim2.new(0, 4, 0, 0)
            enLbl.BackgroundTransparency = 1
            enLbl.Text = glove.en
            enLbl.TextSize = currentP2FontSize
            enLbl.Font = Enum.Font.GothamBold
            enLbl.TextColor3 = THEME.textMain
            enLbl.TextXAlignment = Enum.TextXAlignment.Left
            enLbl.TextTruncate = Enum.TextTruncate.AtEnd
            enLbl.Parent = btn

            local zhLbl = Instance.new("TextLabel")
            zhLbl.Size = UDim2.new(0.3, 0, 1, 0)
            zhLbl.Position = UDim2.new(0.5, 0, 0, 0)
            zhLbl.BackgroundTransparency = 1
            zhLbl.Text = glove.zh
            zhLbl.TextSize = currentP2FontSize
            zhLbl.Font = Enum.Font.Gotham
            zhLbl.TextColor3 = THEME.textSub
            zhLbl.TextXAlignment = Enum.TextXAlignment.Left
            zhLbl.TextTruncate = Enum.TextTruncate.AtEnd
            zhLbl.Parent = btn

            local diffLbl = Instance.new("TextLabel")
            diffLbl.Size = UDim2.new(0.2, -4, 1, 0)
            diffLbl.Position = UDim2.new(0.8, 0, 0, 0)
            diffLbl.BackgroundTransparency = 1
            diffLbl.Text = glove.diff
            diffLbl.TextSize = math.max(8, currentP2FontSize - 1)
            diffLbl.Font = Enum.Font.Gotham
            diffLbl.TextColor3 = DIFF_COLOR[glove.diff] or THEME.textMuted
            diffLbl.TextXAlignment = Enum.TextXAlignment.Right
            diffLbl.TextTruncate = Enum.TextTruncate.AtEnd
            diffLbl.Parent = btn

            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

            local capturedGlove = glove
            btn.MouseButton1Click:Connect(function()
                -- 先填充詳細內容，再切換畫面
                detailEnLbl.Text = capturedGlove.en
                detailZhLbl.Text = capturedGlove.zh
                detailDiffLbl.Text = "難度：" .. capturedGlove.diff
                detailDiffLbl.TextColor3 = DIFF_COLOR[capturedGlove.diff] or THEME.textMuted
                detailDescLbl.Text = capturedGlove.desc

                searchView.Visible = false
                detailView.Visible = true
                -- 重置詳細滾動位置
                detailScroll.CanvasPosition = Vector2.new(0, 0)
            end)

            btn.MouseEnter:Connect(function() btn.BackgroundColor3 = THEME.activeRow end)
            btn.MouseLeave:Connect(function() btn.BackgroundColor3 = THEME.bgRow end)

            table.insert(currentSearchBtns, btn)
        end
    end

    resultCountLabel.Text = string.format("共 %d 個", count)
end

