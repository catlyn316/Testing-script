local function doScan()
    local targetName = targetInput.Text
    local targetPlayer = nil

    if targetName == "" then
        targetPlayer = player
    else
        targetName = targetName:lower()
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():sub(1, #targetName) == targetName
            or p.DisplayName:lower():sub(1, #targetName) == targetName then
                targetPlayer = p; break
            end
        end
    end

    if not targetPlayer then
        statusLbl.Text = "找不到玩家"
        statusLbl.TextColor3 = THEME.red
        return
    end

    statusLbl.Text = "偵測中..."
    statusLbl.TextColor3 = THEME.accent

    clearScrollFrame(haveScroll)
    clearScrollFrame(missingScroll)

    task.spawn(function()
        local unlockedGloves = targetPlayer:FindFirstChild("_unlockedGloves")

        if not unlockedGloves then
            local t0 = tick()
            while not unlockedGloves and tick() - t0 < 5 do
                task.wait(0.2)
                unlockedGloves = targetPlayer:FindFirstChild("_unlockedGloves")
            end
        end

        if not unlockedGloves then
            statusLbl.Text = "找不到_unlockedGloves"
            statusLbl.TextColor3 = THEME.red
            return
        end

        local haveCount = 0
        local missingCount = 0

        for _, glove in ipairs(GLOVE_DATA) do
            -- 決定要偵測的 key：優先使用 detectKey，否則用 en
            local key = glove.detectKey or glove.en
            local child = unlockedGloves:FindFirstChild(key)
            -- child 存在且 value 為 true → 已解鎖；不存在或 value 為 false → 未解鎖
            local hasIt = child ~= nil and (child.Value == true)
            if hasIt then
                addGloveEntry(haveScroll, glove, true)
                haveCount = haveCount + 1
            else
                addGloveEntry(missingScroll, glove, false)
                missingCount = missingCount + 1
            end
        end

        haveTitle.Text = string.format("✅ 已解鎖 (%d)", haveCount)
        missingTitle.Text = string.format("❌ 未解鎖 (%d)", missingCount)
        statusLbl.Text = string.format("完成 %s", targetPlayer.Name)
        statusLbl.TextColor3 = THEME.green
    end)
end

